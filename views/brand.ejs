<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Front page</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="dev-bar">

      <h1 class="Register" onclick="window.location.href='/thirdpage'">Register</h1>  
      <h1 class="Logine" onclick="window.location.href='/fourthpage'">Logine</h1>
      <h1 class="List" onclick="window.location.href='/List'">List</h1>
   
    </div>
    <div class="form">
        <h1>Customer Shopping page</h1>
        <form action="/brand" class="to-do-form" method="post">
            <input type="text" name="customer_Adhar_card_no" value="<%= aadhar %>" class="input1" readonly>
            <br><br>
            <input type="text" class="input1" name="brand_name" placeholder="Enter Brand Name" required>
            <br><br>
            <input type="number" class="input1" name="brand_price" placeholder="Enter Brand Price" id="value" required>
            <br><br>
            <input type="date" class="input1" name="date" placeholder="Enter Today date" id="value" required>
            <br><br>
            <input type="time" class="input1" name="time" placeholder="Enter Today time" id="value" required>
            <br><br>
           
            <button class="button" id="buyBtn">Save</button>
             <h2 id="timer" class="timer"></h2>
        </form>

<script>

const btn = document.getElementById("buyBtn");
const timer = document.getElementById("timer");

<% if(lastPurchase){ %>

const purchaseDate = new Date("<%= lastPurchase.purchaseDate %>").getTime();
const endTime = purchaseDate + (7 * 24 * 60 * 60 * 1000);

function updateTimer(){

    const diff = endTime - Date.now();

    if(diff <= 0){
        timer.innerHTML = "✅ Purchase Allowed";
        btn.disabled = false;
        return;
    }

    btn.disabled = true;

    const days = Math.floor(diff/(1000*60*60*24));
    const hours = Math.floor((diff%(1000*60*60*24))/(1000*60*60));
    const minutes = Math.floor((diff%(1000*60*60))/(1000*60));
    const seconds = Math.floor((diff%(1000*60))/1000);

    timer.innerHTML =
    `Next Purchase after : ${days}d ${hours}h ${minutes}m ${seconds}s`;

}

updateTimer();
setInterval(updateTimer,1000);

<% } else { %>

timer.innerHTML = "✅ First Purchase Allowed";

<% } %>

</script>
    </div>
</body>

</html>